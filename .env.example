# ─── Required ───────────────────────────────────────────────────────────────
# OpenAI API key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Member login password (shared with your community)
MEMBER_PASSWORD=your-member-password-here

# Admin login password (keep this private — gives access to prompt & file management)
ADMIN_PASSWORD=your-admin-password-here

# ─── Optional ───────────────────────────────────────────────────────────────
# OpenAI model to use (default: gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini

# OpenAI Vector Store ID for document search (from https://platform.openai.com/storage)
OPENAI_VECTOR_STORE_ID=vs_...

# Response temperature 0–2 (default: 1)
OPENAI_TEMPERATURE=1

# ─── Vercel KV (optional — used to persist the admin system prompt) ──────────
# Auto-populated when you add a KV store in your Vercel project dashboard
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
